<!DOCTYPE html>
<html>
<head>
<style>
  .custom-frame {
    border: 2px solid #333;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
</style>
</head>
<body>

<h2>Embedded Wikipedia Example</h2>
<iframe 
  src="https://wikipedia.org" 
  width="100%" 
  height="400" 
  title="Wikipedia" 
  class="custom-frame">
</iframe>

</body>
</html>
